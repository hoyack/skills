# Copy this file to a local .env only if your shell workflow needs it.
# Do not commit real API keys.

# Required: Ollama Cloud API key.
OLLAMA_API_KEY=

# Optional deployment settings.
HERMES_AGENT_NAME=
HERMES_HOST_PORT=
HERMES_MODEL=glm-5.2:cloud
HERMES_IMAGE=nousresearch/hermes-agent:latest
HERMES_DATA_PARENT=$HOME/.hermes-agents
HERMES_TIMEZONE=America/Chicago
SEARXNG_URL=https://searxng.hoyack.ai
