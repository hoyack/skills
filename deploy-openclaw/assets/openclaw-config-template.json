{
  "agents": {
    "defaults": {
      "model": {
        "primary": "{{MODEL_PROVIDER}}/{{MODEL_ID}}"
      },
      "workspace": "/data/workspace"
    }
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{AUTH_TOKEN}}"
    },
    "bind": "lan",
    "mode": "local",
    "port": 18789
  },
  "models": {
    "mode": "merge",
    "providers": {
      "{{MODEL_PROVIDER}}": {
        "baseUrl": "{{MODEL_BASE_URL}}",
        "api": "{{MODEL_API_TYPE}}",
        "apiKey": "{{MODEL_API_KEY}}",
        "models": [
          {
            "id": "{{MODEL_ID}}",
            "name": "{{MODEL_NAME}}",
            "reasoning": true,
            "input": ["text", "image"],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": {{MODEL_CONTEXT_WINDOW}},
            "maxTokens": {{MODEL_MAX_TOKENS}}
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "{{SEARXNG_URL}}"
          }
        }
      },
      "firecrawl": {
        "enabled": true,
        "config": {
          "webFetch": {
            "baseUrl": "{{FIRECRAWL_URL}}"
          },
          "webSearch": {
            "baseUrl": "{{FIRECRAWL_URL}}"
          }
        }
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "provider": "searxng"
      },
      "fetch": {
        "provider": "firecrawl"
      }
    }
  }
}
